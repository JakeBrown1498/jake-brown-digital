---
import { sanity } from "../../lib/sanity.js";
import { PortableText } from "astro-portabletext";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import SpotifyCard from "../../components/SpotifyCard.astro";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const weeknotes = await sanity.fetch(`
    *[_type == "weeknotesV2" && defined(slug.current)] {
      "slug": slug.current
    }
  `);

  return weeknotes
    .filter((weeknote: { slug: string }) => weeknote.slug)
    .map((weeknote: { slug: string }) => ({
      params: { slug: weeknote.slug },
    }));
}

const { slug } = Astro.params;

const weeknote = await sanity.fetch(
  `
  *[_type == "weeknotesV2" && slug.current == $slug][0] {
    _id,
    title,
    publishedAt,
    "heroImageUrl": heroImage.asset->url,
    "heroImageHotspot": heroImage.hotspot,
    intro,
    work,
    read,
    listen {
      focus,
      music[] {
        spotifyUrl,
        artist,
        song,
        rating,
        genre
      }
    },
    play {
      sports,
      watch[] {
        title,
        rating
      },
      other
    }
  }
`,
  { slug }
);

if (!weeknote) {
  return Astro.redirect("/404");
}

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Weeknotes", href: "/weeknotes" },
  { label: weeknote.title },
];

const hotspot = weeknote.heroImageHotspot;
const objectPosition = hotspot
  ? `${hotspot.x * 100}% ${hotspot.y * 100}%`
  : 'center center';

const formattedDate = new Date(weeknote.publishedAt).toLocaleDateString('en-GB', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});

const renderStars = (rating: number) => {
  return '★'.repeat(rating) + '☆'.repeat(5 - rating);
};
---

<Layout title={`${weeknote.title} - Jake Brown`}>
    <Nav />

    <!-- Hero -->
    <section class="weeknote-hero">
      <div class="article-column">
        <div class="hero-breadcrumbs">
          <Breadcrumbs items={breadcrumbs} />
        </div>
        <h1 class="weeknote-title">{weeknote.title}</h1>
        <time class="weeknote-date" datetime={weeknote.publishedAt}>{formattedDate}</time>
        {weeknote.heroImageUrl && (
          <div class="hero-image-full">
            <img src={weeknote.heroImageUrl} alt={weeknote.title} style={`object-position: ${objectPosition}`} />
          </div>
        )}
      </div>
    </section>

    <!-- Article body -->
    <div class="article-body">
      <div class="article-column">

        {weeknote.intro && weeknote.intro.length > 0 && (
          <section class="weeknote-section weeknote-intro">
            <PortableText value={weeknote.intro} />
          </section>
        )}

        {weeknote.work && weeknote.work.length > 0 && (
          <section class="weeknote-section">
            <h2 class="h2-primary section-heading">Work</h2>
            <PortableText value={weeknote.work} />
          </section>
        )}

        {weeknote.read && (
          <section class="weeknote-section">
            <h2 class="h2-primary section-heading">Read 📚</h2>
            {weeknote.read.work && weeknote.read.work.length > 0 && (
              <div class="subsection">
                <h3 class="h3-primary">Work</h3>
                <PortableText value={weeknote.read.work} />
              </div>
            )}
            {weeknote.read.fun && weeknote.read.fun.length > 0 && (
              <div class="subsection">
                <h3 class="h3-primary">Fun</h3>
                <PortableText value={weeknote.read.fun} />
              </div>
            )}
          </section>
        )}

        {weeknote.listen && (
          <section class="weeknote-section">
            <h2 class="h2-primary section-heading">Listen 🎧</h2>
            {weeknote.listen.focus && weeknote.listen.focus.length > 0 && (
              <div class="subsection">
                <h3 class="h3-primary">Focus</h3>
                <PortableText value={weeknote.listen.focus} />
              </div>
            )}
            {weeknote.listen.music && weeknote.listen.music.length > 0 && (
              <div class="subsection">
                <h3 class="h3-primary">Music</h3>
                <div class="spotify-grid">
                  {weeknote.listen.music.map((track: { spotifyUrl: string }) => (
                    <SpotifyCard url={track.spotifyUrl} />
                  ))}
                </div>
              </div>
            )}
          </section>
        )}

        {weeknote.play && (
          <section class="weeknote-section">
            <h2 class="h2-primary section-heading">Play 🕹️</h2>
            {weeknote.play.sports && weeknote.play.sports.length > 0 && (
              <div class="subsection">
                <h3 class="h3-primary">Sports</h3>
                <PortableText value={weeknote.play.sports} />
              </div>
            )}
            {weeknote.play.watch && weeknote.play.watch.length > 0 && (
              <div class="subsection">
                <h3 class="h3-primary">Watch</h3>
                <ul class="watch-list">
                  {weeknote.play.watch.map((item: { title: string; rating: number }) => (
                    <li class="watch-item">
                      <span class="watch-rating">{renderStars(item.rating || 0)}</span>
                      <span class="watch-title">{item.title}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </section>
        )}

        {weeknote.play?.other && weeknote.play.other.length > 0 && (
          <section class="weeknote-section">
            <h2 class="h2-primary section-heading">Other</h2>
            <PortableText value={weeknote.play.other} />
          </section>
        )}

      </div>
    </div>

    <Footer />
</Layout>

<style>
  /* Shared narrow column */
  .article-column {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* Hero */
  .weeknote-hero {
    background-color: var(--color--primary-light);
    padding-top: 56px;
    padding-bottom: 56px;
  }

  .hero-breadcrumbs {
    margin-bottom: 24px;
  }

  .weeknote-title {
    font-family: var(--font-family);
    font-size: clamp(40px, 6vw, 64px);
    font-weight: 700;
    color: var(--color--primary-dark);
    line-height: 1.1;
    margin-bottom: 12px;
  }

  .weeknote-date {
    display: block;
    font-family: var(--font-family);
    font-size: var(--font-size-sm);
    color: var(--color--secondary-black);
    margin-bottom: 40px;
  }

  .hero-image-full {
    max-width: 484.5px;
    height: 323px;
    overflow: hidden;
    margin-top: 8px;
  }

  .hero-image-full img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Article body */
  .article-body {
    background-color: var(--color--secondary-background);
    padding: 64px 0 80px;
  }

  /* Sections */
  .weeknote-section {
    margin-bottom: 56px;
  }

  .weeknote-intro {
    font-size: 18px;
    line-height: 1.8;
    color: var(--color--secondary-black);
    font-family: var(--font-family);
  }

  .section-heading {
    padding-bottom: 12px;
    border-bottom: 2px solid var(--color--primary-light);
    margin-bottom: 40px;
  }

  /* PortableText body text */
  .weeknote-section :global(p) {
    font-family: var(--font-family);
    font-size: 18px;
    line-height: 1.8;
    color: var(--color--secondary-black);
    margin-bottom: 16px;
  }

  .weeknote-section :global(a) {
    color: var(--color--primary);
    text-decoration: underline;
  }

  .weeknote-section :global(ul),
  .weeknote-section :global(ol) {
    font-family: var(--font-family);
    font-size: 18px;
    line-height: 1.8;
    color: var(--color--secondary-black);
    padding-left: 24px;
    margin-bottom: 16px;
  }

  /* Subsections */
  .subsection {
    margin-top: 40px;
  }

  .subsection :global(.h3-primary) {
    margin-bottom: 20px;
  }


  /* Spotify */
  .spotify-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-md, 16px);
  }

  /* Watch list */
  .watch-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .watch-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-family);
    font-size: var(--font-size-base);
  }

  .watch-rating {
    color: #f5c518;
    letter-spacing: 1px;
  }

  .watch-title {
    color: var(--color--secondary-black);
  }
</style>
