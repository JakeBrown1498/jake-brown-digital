---
import { sanity } from "../lib/sanity.js";
import Nav from "../components/Nav.astro";
import ContactForm from '../components/ContactForm.astro';
import HeroHeader from '../components/HeroHeader.astro';
import Footer from '../components/Footer.astro';
import SpotifyCard from '../components/SpotifyCard.astro';
import LogoBanner from '../components/LogoBanner.astro';


const homepage = await sanity.fetch(`
  *[_type == "homepage"][0] {
    heroImage,
    heroHeading,
    heroIntro,
    services,
    featuredWeeknotes[]->{
      title,
      publishedAt,
      slug,
      intro
    },
    contactHeading,
    contactIntro,
    contactPoints,
    socialLinks
  }
`);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href='https://fonts.googleapis.com/css2?family=Poppins:wght@400;700&display=swap' rel='stylesheet'>
    <title>Jake Brown - Digital Experience Leader</title>
    
    <style>
    .what-i-do-container {
      display: flex;
      flex-direction: column;
      align-items: left;
      padding: 32px 32px;
    }

    .what-i-do-container {
      display: flex;
      flex-direction: column;
      gap: 32px;
    }
    .what-i-do-block {
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
    }


    </style>
  </head>

<!-- End of Head -->

<!-- Navigation-->
    <Nav />

<!-- Main Content -->
    <main>

<!-- Hero Header -->
    <HeroHeader />

<!-- Logo Banner -->
    <LogoBanner />


<!-- What I Do -->
    <section class="what-i-do-container">
      <div class="what-i-do-block">
        <h3 class="h3-primary">Digital experience and content</h3>
        <p class="body-sm-black">Lorem ipsum dolor sit amet consectetur. Neque pulvinar duis tristique nisl at. Arcu diam quis odio euismod aliquet aliquet aliquam vel fermentum.</p>
      </div>
      <div class="what-i-do-block">
        <h3 class="h3-primary">Digital product</h3>
        <p class="body-sm-black">Lorem ipsum dolor sit amet consectetur. Neque pulvinar duis tristique nisl at. Arcu diam quis odio euismod aliquet aliquet aliquam vel fermentum.</p>
      </div>
      <div class="what-i-do-block">
        <h3 class="h3-primary">Digital strategy</h3>
        <p class="body-sm-black">Lorem ipsum dolor sit amet consectetur. Neque pulvinar duis tristique nisl at. Arcu diam quis odio euismod aliquet aliquet aliquam vel fermentum.</p>
      </div>
    </section>

      <!-- Spotify -->
      <section class="spotify container" style="padding: 2rem 0;">
        <SpotifyCard url="https://open.spotify.com/track/4cOdK2wGLETKBW3PvgPWqT" />
      </section>

      
      <!-- Weeknotes -->
      <section class="weeknotes-section">
        <div class="container">
          <h2>Weeknotes</h2>
          {
            homepage.featuredWeeknotes?.map((weeknote) => (
              <a
                href={`/weeknotes-v2/${weeknote.slug.current}`}
                class="weeknote-card"
              >
                <h3>{weeknote.title}</h3>
                <time>
                  {new Date(weeknote.publishedAt).toLocaleDateString()}
                </time>
                {weeknote.intro && (
                  <p>{weeknote.intro[0]?.children[0]?.text}</p>
                )}
              </a>
            ))
          }
        </div>
      </section>

      <!-- Contact -->
      <section class="contact container">
        <h2>{homepage.contactHeading}</h2>
        <p>{homepage.contactIntro}</p>

        {
          homepage.contactPoints && (
            <ul>
              {homepage.contactPoints.map((point) => (
                <li>{point}</li>
              ))}
            </ul>
          )
        }

        <ContactForm />
        
      </section>
    </main>

    <!-- Footer -->
    <Footer />
  </body>
</html>
