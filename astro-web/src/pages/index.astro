---
import { sanity } from "../lib/sanity.js";
import Nav from "../components/Nav.astro";
import ContactForm from '../components/ContactForm.astro';
import HeroHeader from '../components/HeroHeader.astro';
import Footer from '../components/Footer.astro';
import SpotifyCard from '../components/SpotifyCard.astro';
import LogoBanner from '../components/LogoBanner.astro';
import WeeknotesCard from '../components/WeeknotesCard.astro';
import WeeknotesCarousel from "../components/WeeknotesCarousel.astro";
import WorkStatus from "../components/WorkStatus.astro";
import Layout from "../layouts/Layout.astro";

const homepage = await sanity.fetch(`
  *[_type == "homepage"][0] {
    heroImage,
    heroHeading,
    heroIntro,
    services,
    contactHeading,
    contactIntro,
    contactPoints,
    socialLinks
  }
`);

const recentWeeknotes = await sanity.fetch(`
  *[_type == "weeknotesV2" && defined(slug.current)] | order(publishedAt desc)[0...3] {
    title,
    publishedAt,
    "slug": slug.current,
    "imageUrl": heroImage.asset->url
  }
`);
---

<Layout title="Jake Brown - Digital Experience Leader">
  <style slot="head">
    .what-i-do-container {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      padding-top: 64px;
      padding-bottom: 64px;
      background: var(--color--secondary-background);
      gap: 8px;
    }

    .what-i-do-full-block {
      display: flex;
      flex-direction: column;
      gap: 0px;
      width: 100%;
    }

    .what-i-do-pillars-block {
      display: flex;
      flex-direction: row;
      align-items: flex-start;
      justify-content: space-between;
      gap: var(--space-lg, 32px);
    }

    .what-i-do-individual-block {
      flex-direction: column;
      flex: 1;
      display: flex;
      gap: var(--space-md);
    }

    .pillar-icon {
      height: 40px;
      width: auto;
      display: block;
      margin-bottom: calc(-1 * var(--space-md));
    }

    .pillar-icon--1 {
      margin-left: 55%;
    }

    .pillar-icon--2 {
      margin-left: -100%;
    }

    .pillar-icon--3 {
      margin-left: -100%;
    }

    .what-i-do-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .what-i-do-tag {
      border: 1.5px solid var(--color--primary);
      border-radius: 100px;
      padding: 6px 14px;
      font-size: 0.875rem;
      color: var(--color--primary-dark);
      background: transparent;
    }

    .weeknotes-section {
      padding: 32px 0;
      background-color: var(--color--primary-light, #D9CCFF);
    }

    .weeknotes-section h2 {
      margin-bottom: var(--space-md, 16px);
    }

    .weeknotes-grid {
      display: flex;
      flex-direction: column;
      gap: var(--space-md, 16px);
    }

    @media (max-width: 768px) {
      .what-i-do-pillars-block {
        flex-direction: column;
      }

      .pillar-icon {
        display: none;
      }
    }

    </style>

<!-- Navigation-->
    <Nav />

<!-- Main Content -->
    <main>

<!-- Hero Header -->
    <HeroHeader />

<!-- What I Do Container-->
    <section class="what-i-do-container content-wrapper">
      <div class="what-i-do-full-block">
        <h2 class="h2-primary">Thriving in these three areas</h2>

        <!-- What I do Pillars -->
        <div class="what-i-do-pillars-block">
        <div class="what-i-do-individual-block">
          <img src="/Group 3.svg" alt="" class="pillar-icon pillar-icon--1" />
          <h3 class="h3-primary">Digital experience and content</h3>
          <p class="body-sm-black">Specialising in the end-to-end process of researching, designing, developing and shipping user-centric digital experiences and digital content, driven by intent.</p>
          <div class="what-i-do-tags">
            <span class="what-i-do-tag">UX Research</span>
            <span class="what-i-do-tag">UX Design</span>
            <span class="what-i-do-tag">Development</span>
            <span class="what-i-do-tag">Content Design</span>
            <span class="what-i-do-tag">Copywriting</span>
            <span class="what-i-do-tag">SEO</span>
            <span class="what-i-do-tag">Conversion Rate Optimisation</span>
          </div>
        </div>
        <div class="what-i-do-individual-block">
          <img src="/Group 4.svg" alt="" class="pillar-icon pillar-icon--2" />
          <h3 class="h3-primary">Digital product</h3>
          <p class="body-sm-black">Experienced in high-output, efficient agile delivery. I help teams establish ways of working, define governance, and build delivery frameworks that ship quality work consistently.</p>
          <div class="what-i-do-tags">
            <span class="what-i-do-tag">Product Discovery</span>
            <span class="what-i-do-tag">User Stories</span>
            <span class="what-i-do-tag">Digital Analytics</span>
            <span class="what-i-do-tag">Product Strategy</span>
            <span class="what-i-do-tag">Agile</span>
            <span class="what-i-do-tag">Process Design</span>
          </div>
        </div>
        <div class="what-i-do-individual-block">
          <img src="/Group 5.svg" alt="" class="pillar-icon pillar-icon--3" />
          <h3 class="h3-primary">Digital delivery</h3>
          <p class="body-sm-black">I help organisations define and execute digital strategies that drive meaningful change, from transformation roadmaps and operating model design to identifying where AI can deliver genuine value.</p>
          <div class="what-i-do-tags">
            <span class="what-i-do-tag">Digital Transformation</span>
            <span class="what-i-do-tag">Architecture</span>
            <span class="what-i-do-tag">Artificial Intelligence</span>
            <span class="what-i-do-tag">Service Design</span>
          </div>
        </div>
      </div>
      </div>
    </section>

<!-- Logo Banner -->
<LogoBanner />

<WeeknotesCarousel />

<WorkStatus />

<ContactForm />
        
      </section>
    </main>

    <!-- Footer -->
    <Footer />
</Layout>
