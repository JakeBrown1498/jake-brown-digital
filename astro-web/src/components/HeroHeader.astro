---
interface Props {
  title?: string;
  subtitle?: string;
}

const { title = "Default Title", subtitle = "Default Subtitle" } = Astro.props;
---

<section class="header-hero-container" id="header-hero-container-full-bleed">
  <div class="hero-image-container-full-bleed">
    <img src="/Frame 81.png" alt="Hero Image" class="hero-image-bleed" />
  </div>

  <div class="hero-text-container hero-text">
    <h1 class="h1--secondary-green">Ciao, my name is Jake Brown.</h1>
    <p class="body-base-neutral">I build digital products for nonprofits, public services and generally for fun. Weeknotes on what I'm learning, shipping, and breaking along the way.</p>
  </div>
</section>

<style>
/* Mobile hero (default) */
.header-hero-container {
  display: flex;
  flex-direction: column;
  width: 100%;
  margin: 0;
}

.hero-image-container-full-bleed {
  position: relative;
  display: flex;
  width: 100%;
  overflow: hidden;
  box-sizing: border-box;
}

.hero-image-bleed {
  max-width: calc(100% - 64px);
  min-width: 329px;
  height: auto;
  margin: 0 auto;
}

/* Mobile: text below image */
.hero-text-container {
  display: flex;
  flex-direction: column;
  margin-top: 32px;
  padding: 32px 32px;
  padding-bottom: 32px;
  text-align: left;
  background-color: var(--color--primary-dark);
  gap: 8px;
}

.hero-text-container h1 {
  margin-bottom: 0;
}

.hero-text-container p {
  margin: 0;
}

/* Desktop hero */
@media (min-width: 769px) {
  .header-hero-container {
    position: relative;
  }

  .hero-image-container-full-bleed {
    max-width: 100%;
    max-height: 504px;
    margin: 0 auto;
  }

  .hero-image-bleed {
    width: 100%;
    height: 504px;
    object-fit: cover;
    object-position: right center;
  }

  /* Desktop: overlay on image */

  .hero-text {
    position: absolute;
    left: 64px;
    top: 50%;
    transform: translateY(-50%);
    max-width: 500px;
    padding: 0;
    color: #FFFFFF;
  }

  .hero-title {
    font-size: 3rem;
  }

  .hero-subtitle {
    font-size: 1.25rem;
  }
}
</style>

