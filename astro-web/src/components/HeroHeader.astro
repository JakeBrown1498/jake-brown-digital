---
---

<section class="header-hero-container">
  <div class="header-hero-content-wrapper">
    <!-- Hero text and button wrapper -->
    <div class="hero-text-wrapper">
      <h1 class="h1--secondary-white">Ciao, my name is Jake Brown <span class="hero-initials-wrapper"><span class="hero-initials">{`{JB}`}</span><img src="/Vector 10.png" alt="" class="hero-vector" /></span></h1>
      <p class="body-base-neutral">Leader helping NGO and public sector organisations deliver user-centric digital products. Love shipping data-driven things at speed.</p>
      <a class="secondary-button" href="/weeknotes">Read my weeknotes</a>
    </div>

    <!-- Hero image -->
    <div class="hero-image-container">
      <img src="/JBD_LargeHeadshot.png" alt="Jake Brown" class="hero-image" />
    </div>
  </div>
</section>

<style>

.header-hero-container {
  background-color: var(--color--primary-dark);
  width: 100%;
}

.header-hero-content-wrapper {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  max-width: 1200px;
  margin: 0 auto;
  padding: 64px 54px;
  gap: 48px;
}

.hero-text-wrapper {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 24px;
  flex: 1;
  max-width: 693px;
}

.hero-text-wrapper h1 {
  font-size: 78px;
  font-weight: 700;
  line-height: 1.1;
}

.hero-text-wrapper p {
  font-size: 16px;
}

.hero-initials-wrapper {
  position: relative;
  display: inline-block;
}

.hero-initials {
  color: var(--color--secondary);
}

.hero-vector {
  position: absolute;
  top: 100%;
  left: 0;
  width: 100%;
  height: auto;
}

.hero-image-container {
  flex-shrink: 0;
  border-radius: var(--radius-lg);
  overflow: hidden;
  width: 340px;
  height: 340px;
  background-color: #f0ebe0;
}

.hero-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: top center;
}

.secondary-button {
  display: inline-block;
  background-color: var(--color--secondary);
  color: var(--color--primary-dark);
  font-family: var(--font-family);
  font-size: inherit;
  font-weight: 600;
  padding: 10px 20px;
  border-radius: 26px;
  text-decoration: none;
  border: none;
  cursor: pointer;
}
.secondary-button:hover {
  background-color: var(--color--secondary-white);
  color: var(--color--primary-dark);
}

</style>
