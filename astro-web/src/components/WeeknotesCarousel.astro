---
import { sanity } from "../lib/sanity.js";
import WeeknotesCard from "./WeeknotesCard.astro";

const allWeeknotes = await sanity.fetch(`
  *[_type == "weeknotesV2" && defined(slug.current) && defined(publishedAt)] | order(publishedAt desc) {
    title,
    publishedAt,
    "slug": slug.current,
    "imageUrl": heroImage.asset->url
  }
`);

const ITEMS_PER_PAGE = 6;
const totalPages = Math.ceil((allWeeknotes?.length || 0) / ITEMS_PER_PAGE);
---

<section class="weeknotes-section">
  <div class="content-wrapper">
    <div class="weeknotes-header">
      <div class="weeknotes-header-text">
        <h2 class="h2-primary">Weeknotes</h2>
        <p class="body-sm-black">This is where I get up on my soap box, and journal the past week in and out of work. I note what I've been up to, what I've been learning, and most importantly what I've been thinking.</p>
      </div>
    </div>

    <div class="weeknotes-grid" id="weeknotes-grid">
      {
        allWeeknotes?.map((weeknote: { title: string; publishedAt: string; slug: string; imageUrl?: string }, i: number) => (
          <div class="card-wrapper" data-page={Math.floor(i / ITEMS_PER_PAGE) + 1} style={i >= ITEMS_PER_PAGE ? 'display:none' : ''}>
            <WeeknotesCard
              title={weeknote.title}
              publishedAt={weeknote.publishedAt}
              slug={weeknote.slug}
              imageUrl={weeknote.imageUrl}
            />
          </div>
        ))
      }
    </div>

    <div class="weeknotes-footer">
      <div class="pagination" id="pagination" data-total-pages={totalPages}>
        <button class="pag-btn pag-arrow" id="rewind-btn" disabled aria-label="First page">
          <img src="/Rewind.svg" alt="" />
        </button>

        {Array.from({ length: totalPages }, (_, i) => i + 1).map((page) => (
          <button
            class={`pag-btn pag-page${page === 1 ? ' active' : ''}`}
            data-page={page}
            aria-label={`Page ${page}`}
          >
            {page}
          </button>
        ))}

        {totalPages > 4 && <span class="pag-ellipsis">...</span>}

        <button class="pag-btn pag-arrow" id="forwards-btn" aria-label="Last page">
          <img src="/Forwards.svg" alt="" />
        </button>
      </div>

      <div class="read-all-wrapper">
        <img src="/Group 6.svg" alt="" class="read-all-arrow" />
        <a href="/weeknotes" class="read-all-button">Read all of my weeknotes</a>
      </div>
    </div>
  </div>
</section>

<script>
  const grid = document.getElementById('weeknotes-grid');
  const pagination = document.getElementById('pagination');
  const rewindBtn = document.getElementById('rewind-btn') as HTMLButtonElement;
  const forwardsBtn = document.getElementById('forwards-btn') as HTMLButtonElement;

  const DESKTOP_PER_PAGE = 6;
  const MOBILE_PER_PAGE = 3;
  const cards = Array.from(grid?.querySelectorAll<HTMLElement>('.card-wrapper') || []);
  let currentPage = 1;

  function isMobile() {
    return window.innerWidth < 768;
  }

  function getPerPage() {
    return isMobile() ? MOBILE_PER_PAGE : DESKTOP_PER_PAGE;
  }

  function getTotalPages() {
    return Math.ceil(cards.length / getPerPage());
  }

  function makePageBtn(i: number) {
    const btn = document.createElement('button');
    btn.className = `pag-btn pag-page${i === currentPage ? ' active' : ''}`;
    btn.dataset.page = String(i);
    btn.setAttribute('aria-label', `Page ${i}`);
    btn.textContent = String(i);
    btn.addEventListener('click', () => goToPage(i));
    return btn;
  }

  function rebuildPagination() {
    pagination?.querySelectorAll('.pag-page, .pag-ellipsis').forEach(el => el.remove());
    const total = getTotalPages();

    if (isMobile() && total > 3) {
      // Sliding window of 3 pages centred on current
      let start = Math.max(1, currentPage - 1);
      let end = Math.min(total, start + 2);
      if (end - start < 2) start = Math.max(1, end - 2);

      for (let i = start; i <= end; i++) {
        pagination?.insertBefore(makePageBtn(i), forwardsBtn);
      }

      if (end < total) {
        const ellipsis = document.createElement('span');
        ellipsis.className = 'pag-ellipsis';
        ellipsis.textContent = '...';
        pagination?.insertBefore(ellipsis, forwardsBtn);
      }
    } else {
      for (let i = 1; i <= total; i++) {
        pagination?.insertBefore(makePageBtn(i), forwardsBtn);
      }
    }
  }

  function goToPage(page: number) {
    currentPage = page;
    const perPage = getPerPage();

    cards.forEach((card, index) => {
      const cardPage = Math.floor(index / perPage) + 1;
      card.style.display = cardPage === page ? '' : 'none';
    });

    rebuildPagination();

    if (rewindBtn) rewindBtn.disabled = page === 1;
    if (forwardsBtn) forwardsBtn.disabled = page === getTotalPages();
  }

  function init() {
    currentPage = 1;
    rebuildPagination();
    goToPage(1);
  }

  rewindBtn?.addEventListener('click', () => goToPage(1));
  forwardsBtn?.addEventListener('click', () => goToPage(getTotalPages()));

  init();

  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(init, 150);
  });
</script>

<style>
  .weeknotes-section {
    padding: 64px 0;
    background-color: var(--color--secondary-background);
  }

  .weeknotes-header {
    margin-bottom: 32px;
  }

  .weeknotes-header-text {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 600px;
  }

  .weeknotes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(2, auto);
    gap: var(--space-md, 16px);
    align-items: stretch;
  }

  .card-wrapper {
    height: 100%;
  }

  .weeknotes-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 32px;
  }

  /* Pagination */
  .pagination {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  :global(.pag-btn) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    border: none;
    background-color: var(--color--secondary-white);
    color: var(--color--primary-dark);
    font-family: var(--font-family);
    font-size: var(--font-size-base);
    font-weight: 400;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  :global(.pag-btn:hover:not(:disabled)) {
    background-color: var(--color--primary);
    color: var(--color--secondary-white);
  }

  :global(.pag-btn:disabled) {
    opacity: 0.4;
    cursor: default;
  }

  :global(.pag-btn.active) {
    background-color: var(--color--primary-light);
    color: var(--color--primary-dark);
    font-weight: 600;
  }

  :global(.pag-arrow img) {
    width: 16px;
    height: 16px;
  }

  :global(.pag-ellipsis) {
    color: var(--color--primary-dark);
    font-family: var(--font-family);
    font-weight: 600;
    padding: 0 4px;
  }

  /* CTA */
  .read-all-wrapper {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .read-all-arrow {
    width: 100px;
  }

  .read-all-button {
    display: inline-block;
    background-color: var(--color--primary);
    color: var(--color--secondary-white);
    font-family: var(--font-family);
    font-size: var(--font-size-base);
    font-weight: 600;
    padding: 12px 24px;
    border-radius: 26px;
    text-decoration: none;
  }

  .read-all-button:hover {
    background-color: var(--color--primary-dark);
  }

  @media (max-width: 767px) {
    .weeknotes-grid {
      grid-template-columns: 1fr;
    }

    .weeknotes-footer {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
    }

    .read-all-arrow {
      display: none;
    }
  }
</style>
